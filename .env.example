# SmartAI runs its OWN local LLM — NO API key needed.
# Optionally pick which open-source model to download & run locally.
# Smaller = faster and lighter on RAM. Larger = smarter but heavier.

AI_MODEL=Qwen/Qwen2.5-1.5B-Instruct

# Other good options:
# AI_MODEL=Qwen/Qwen2.5-0.5B-Instruct      # very light, runs on most laptops
# AI_MODEL=meta-llama/Llama-3.2-1B-Instruct
# AI_MODEL=Qwen/Qwen2.5-3B-Instruct        # smarter, needs more RAM / a GPU
