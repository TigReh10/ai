# ---- LLM settings ----
# Your API key. Works with OpenAI out of the box.
OPENAI_API_KEY=sk-your-key-here

# Optional: which model to use (default: gpt-4o-mini)
AI_MODEL=gpt-4o-mini

# Optional: point at any OpenAI-compatible endpoint
# (e.g. OpenRouter, Groq, Together, a local server like Ollama/LM Studio)
# OPENAI_BASE_URL=https://api.openai.com/v1
